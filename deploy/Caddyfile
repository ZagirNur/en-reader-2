# en-reader Caddyfile (M17.5/M17.6/M17.7).
#
# Cloudflare terminates TLS in front of the origin and proxies to us
# over HTTP (port 80). Caddy here is a plain-HTTP reverse proxy to the
# uvicorn worker on 127.0.0.1:8080 — no auto-TLS, no HTTPS listener,
# no HTTP→HTTPS redirect (which would loop through Cloudflare).
#
# M17.7 adds /_debug/ paths that survive even when uvicorn is down, so a
# busted cloud-init or crashed app is still diagnosable from the
# sandbox over HTTP without an SSH session. The paths read log files
# that were scrubbed of secrets at write time (bootstrap flips off
# `set -x` before writing .env).
{
  auto_https off
}

:80 {
  @debug_log path /_debug/log
  handle @debug_log {
    root * /var/log
    rewrite * /en-reader-bootstrap.log
    file_server
  }
  @debug_status path /_debug/status
  handle @debug_status {
    root * /var/log
    rewrite * /status.txt
    file_server
  }
  handle {
    reverse_proxy 127.0.0.1:8080
    encode gzip
    header {
      Strict-Transport-Security "max-age=31536000; includeSubDomains"
      X-Content-Type-Options "nosniff"
      Referrer-Policy "no-referrer-when-downgrade"
      # M18.2c: Cloudflare was caching /static/app.js for 4h by default,
      # which meant every client-side fix had to wait a cache cycle before
      # reaching users. Tell CF (and browsers) to always revalidate. If
      # hotspots like fonts become a perf issue later we can lift this on
      # a per-path basis.
      Cache-Control "no-store, must-revalidate"
    }
  }
}
