# en-reader Caddyfile (M17.5).
#
# Cloudflare terminates TLS in front of the origin and proxies to us
# over HTTP (port 80). Caddy here is a plain-HTTP reverse proxy to the
# uvicorn worker on 127.0.0.1:8080 — no auto-TLS, no HTTPS listener,
# no HTTP→HTTPS redirect (which would loop through Cloudflare). HSTS
# and the rest of the security headers are set here too so they travel
# through CF untouched.
{
  auto_https off
}

:80 {
  reverse_proxy 127.0.0.1:8080
  encode gzip
  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains"
    X-Content-Type-Options "nosniff"
    Referrer-Policy "no-referrer-when-downgrade"
  }
}
